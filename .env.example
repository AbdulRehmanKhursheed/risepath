# Add your Anthropic API key for the AI motivation coach
EXPO_PUBLIC_CLAUDE_KEY=your_anthropic_api_key_here

# ── Google AdMob ─────────────────────────────────────────────────────────────
# Replace with your real AdMob App IDs in app.json (androidAppId / iosAppId).
# Then add your real Banner Ad Unit IDs here for production builds.
# In development the app automatically uses Google's official test ad unit IDs.
EXPO_PUBLIC_ADMOB_BANNER_HOME=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
EXPO_PUBLIC_ADMOB_BANNER_STATS=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
