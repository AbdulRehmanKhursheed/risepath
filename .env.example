# ─── Google AdMob ──────────────────────────────────────────────
# Banner ad unit IDs. Used on Home and Stats screens only.
# In dev (NODE_ENV !== 'production') the app automatically substitutes
# Google's public test unit IDs, so you can leave real IDs here safely.
EXPO_PUBLIC_ADMOB_BANNER_HOME=ca-app-pub-6562347670701476/1464122496
EXPO_PUBLIC_ADMOB_BANNER_STATS=ca-app-pub-6562347670701476/5813577418

# ─── Sentry (crash reporting) ──────────────────────────────────
# Paste the DSN from your Sentry project (https://sentry.io → Project → Settings).
# When empty, crash reporting is disabled (no-op). Safe to commit empty.
EXPO_PUBLIC_SENTRY_DSN=
